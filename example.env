# Server
PORT=3002
MPP_SECRET_KEY=replace-with-a-long-random-demo-secret
MPP_REALM=localhost:3002

# Stellar Testnet payment settings
STELLAR_NETWORK=stellar:testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RECIPIENT=G_REPLACE_WITH_SERVER_RECIPIENT_PUBLIC_KEY
STELLAR_RECIPIENT_SECRET=S_REPLACE_WITH_SERVER_RECIPIENT_SECRET_FOR_CHANNEL_CLOSE

# Demo token contract.
# Default: native XLM SAC on Testnet, easiest for a live workshop.
# USDC SAC Testnet from the Stellar skill: CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
STELLAR_TOKEN_CONTRACT=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
STELLAR_TOKEN_LABEL=XLM
STELLAR_TOKEN_DECIMALS=7

# Price per paid request, in human units.
MPP_PRICE=0.00001

# Optional: server sponsors Soroban fees in pull mode.
FEE_PAYER_SECRET=

# Required for channel mode. Build/deploy the one-way-channel contract and set
# the deployed contract plus raw ed25519 commitment key values.
CHANNEL_CONTRACT=
COMMITMENT_SECRET=
COMMITMENT_PUBKEY=
CHANNEL_DEPOSIT=0.001

# Client
STELLAR_SECRET_KEY=S_REPLACE_WITH_CLIENT_SECRET_KEY
API_BASE_URL=http://localhost:3002
